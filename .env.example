# --- Core ---------------------------------------------------------------
# Any long random string. Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# "development" (default) or "production". Production refuses to boot with
# missing secrets and turns on secure cookies + https URL scheme.
APP_ENV=development

# Public base URL of the site (used to build magic-link emails).
SITE_URL=http://localhost:5000

# Where contact-form messages are emailed. (The owner/admin account itself
# is created in the browser at /setup — no env vars involved.)
ADMIN_EMAIL=you@example.com

# --- Database -------------------------------------------------------------
# Leave unset locally to use SQLite (firstlight-dev.db in the project root).
# On Render this is injected from the managed Postgres database.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Email (any SMTP relay: Resend, Postmark, Mailgun, ...) ---------------
# Leave SMTP_HOST empty in dev: emails (incl. magic links) print to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="First Light <hello@example.com>"

# --- Lemon Squeezy ---------------------------------------------------------
# API key:        LS dashboard -> Settings -> API -> "+" (create key)
# Webhook secret: LS dashboard -> Settings -> Webhooks -> your webhook's signing secret
# Store ID:       LS dashboard -> Settings -> Stores (the number in the URL / list)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=change-me-too
LEMONSQUEEZY_STORE_ID=
